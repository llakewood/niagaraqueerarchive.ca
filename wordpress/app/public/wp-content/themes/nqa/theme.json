{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{ "slug": "nqa-base",   "color": "#ffffff",  "name": "Base" },
				{ "slug": "nqa-ink",    "color": "#111111",  "name": "Ink" },
				{ "slug": "nqa-cream",  "color": "#FBFAF3",  "name": "Cream" },
				{ "slug": "nqa-violet", "color": "#503AA8",  "name": "Violet" },
				{ "slug": "nqa-yellow", "color": "#FFEE58",  "name": "Yellow" },
				{ "slug": "nqa-pink",   "color": "#F6CFF4",  "name": "Pink" }
			],
			"gradients": [
				{
					"slug": "nqa-pride-stripe",
					"gradient": "linear-gradient(to right, #e40303, #ff8c00, #ffed00, #008026, #004dff, #750787)",
					"name": "Pride Stripe"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1480px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "slug": "10", "size": "0.5rem",                    "name": "2xs" },
				{ "slug": "20", "size": "1rem",                      "name": "xs" },
				{ "slug": "30", "size": "1.5rem",                    "name": "sm" },
				{ "slug": "40", "size": "clamp(1.5rem, 3vw, 2rem)", "name": "md" },
				{ "slug": "50", "size": "clamp(2rem, 5vw, 3.5rem)", "name": "lg" },
				{ "slug": "60", "size": "clamp(3rem, 7vw, 5rem)",   "name": "xl" },
				{ "slug": "70", "size": "clamp(4rem, 9vw, 7rem)",   "name": "2xl" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "nqa-sans",
					"name": "DM Sans",
					"fontFamily": "'DM Sans', system-ui, sans-serif"
				},
				{
					"slug": "nqa-serif",
					"name": "Fraunces",
					"fontFamily": "'Fraunces', Georgia, serif"
				},
				{
					"slug": "nqa-mono",
					"name": "Space Mono",
					"fontFamily": "'Space Mono', 'Courier New', monospace"
				}
			],
			"fontSizes": [
				{ "slug": "xs",   "size": "0.8rem",                      "name": "XS" },
				{ "slug": "sm",   "size": "0.9rem",                      "name": "SM" },
				{ "slug": "md",   "size": "1rem",                        "name": "MD" },
				{ "slug": "lg",   "size": "1.125rem",                    "name": "LG" },
				{ "slug": "xl",   "size": "clamp(1.25rem, 2.5vw, 1.5rem)", "name": "XL" },
				{ "slug": "2xl",  "size": "clamp(1.5rem, 3vw, 2rem)",    "name": "2XL" },
				{ "slug": "3xl",  "size": "clamp(1.75rem, 3.5vw, 2.5rem)", "name": "3XL" },
				{ "slug": "4xl",  "size": "clamp(2rem, 5vw, 3.5rem)",    "name": "4XL" },
				{ "slug": "5xl",  "size": "clamp(2.5rem, 6vw, 5rem)",    "name": "5XL" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "#ffffff",
			"text": "#111111"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--nqa-sans)",
			"fontSize": "18px",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--40)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-serif)",
					"fontSize":   "var(--wp--preset--font-size--4xl)",
					"lineHeight": "1.1",
					"fontWeight": "700"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-serif)",
					"fontSize":   "var(--wp--preset--font-size--3xl)",
					"lineHeight": "1.15",
					"fontWeight": "700"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-serif)",
					"fontSize":   "var(--wp--preset--font-size--2xl)",
					"lineHeight": "1.2",
					"fontWeight": "700"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-serif)",
					"fontSize":   "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.25",
					"fontWeight": "700"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-sans)",
					"fontSize":   "var(--wp--preset--font-size--md)",
					"lineHeight": "1.3",
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "0.08em"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-mono)",
					"fontSize":   "var(--wp--preset--font-size--sm)",
					"lineHeight": "1.4",
					"fontWeight": "400",
					"textTransform": "uppercase",
					"letterSpacing": "0.12em"
				}
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--nqa-violet)" },
				"typography": { "textDecoration": "underline" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--nqa-ink)" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--nqa-violet)",
					"text": "#ffffff"
				},
				"border": {
					"width": "2px",
					"style": "solid",
					"color": "var(--wp--preset--color--nqa-ink)",
					"radius": "0"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-mono)",
					"fontSize":   "var(--wp--preset--font-size--xs)",
					"fontWeight": "700",
					"textTransform": "uppercase",
					"letterSpacing": "0.1em"
				},
				"spacing": {
					"padding": {
						"top":    "0.75rem",
						"bottom": "0.75rem",
						"left":   "1.5rem",
						"right":  "1.5rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--nqa-ink)",
						"text": "#ffffff"
					}
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-serif)",
					"fontSize":   "var(--wp--preset--font-size--4xl)",
					"lineHeight": "1.1"
				}
			},
			"core/query-pagination": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--nqa-mono)",
					"fontSize":   "var(--wp--preset--font-size--xs)",
					"textTransform": "uppercase",
					"letterSpacing": "0.08em"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-no-title", "title": "Page (No Title)",   "postTypes": ["page"] },
		{ "name": "page-wide",     "title": "Page (Wide)",        "postTypes": ["page"] }
	]
}
