# ─────────────────────────────────────────────────────────────────────────
# Whitelist strategy: ignore EVERYTHING, then re-include only what we track.
# The WP site lives under Local's layout: wordpress/app/public/wp-content/.
# We track project meta + that wp-content/themes only. WP core, plugins,
# uploads, db, Local logs/conf, secrets, and /data all stay out by default.
# ─────────────────────────────────────────────────────────────────────────

# 1. Ignore everything at the repo root...
/*

# 2. ...but keep project meta files & dirs.
!.gitignore
!.github/
!docs/
!README.md
!CLAUDE.md

# 3. Descend through Local's nesting to reach wp-content/themes.
#    Each level: re-include the dir, then ignore its contents, then go deeper.
!wordpress/
wordpress/*
!wordpress/app/
wordpress/app/*
!wordpress/app/public/
wordpress/app/public/*
!wordpress/app/public/wp-content/
wordpress/app/public/wp-content/*
!wordpress/app/public/wp-content/themes/
wordpress/app/public/wp-content/themes/*
!wordpress/app/public/wp-content/themes/index.php
!wordpress/app/public/wp-content/themes/twentytwentyfive/

# mu-plugins: track our secret-free NQA code. The runtime-secrets file
# (0-nqa-runtime-config.php) starts with "0-" so it is NOT matched here — it is
# injected by CI / set locally and never tracked.
#   - nqa-archive.php        : the loader (top-level file WordPress auto-loads)
#   - nqa-archive/**         : the loader's modules (a subdirectory, so it needs
#                              its own re-include; "nqa-*.php" only matches files)
!wordpress/app/public/wp-content/mu-plugins/
wordpress/app/public/wp-content/mu-plugins/*
!wordpress/app/public/wp-content/mu-plugins/nqa-*.php
!wordpress/app/public/wp-content/mu-plugins/nqa-archive/
!wordpress/app/public/wp-content/mu-plugins/nqa-archive/**

# 4. Custom plugins — when we build one, add an exception like:
#    !wordpress/app/public/wp-content/plugins/
#    wordpress/app/public/wp-content/plugins/*
#    !wordpress/app/public/wp-content/plugins/nqa-<name>/

# ─── Always ignore these, even inside tracked dirs (last match wins) ───
.DS_Store
Thumbs.db
*.swp
node_modules/
vendor/
*.log
*.sql
*.sql.gz
.env
.env.*
wp-config.php
wp-config-local.php
auth.json
