# ─────────────────────────────────────────────────────────────────────────
# Whitelist strategy: ignore EVERYTHING, then re-include only what we track.
# We commit project meta + wp-content/themes + wp-content/uploads.
# WP core, database, secrets, and /data (personal info) stay out by default.
# ─────────────────────────────────────────────────────────────────────────

# 1. Ignore everything at the repo root...
/*

# 2. ...but keep project meta files & dirs.
!.gitignore
!.github/
!docs/
!README.md
!CLAUDE.md

# 3. WordPress: descend into wp-content, ignore its contents, re-include the
#    directories we want.
!wp-content/
wp-content/*
!wp-content/themes/
!wp-content/uploads/

# 4. Custom plugins — when we build one, add an exception like:
#    !wp-content/plugins/
#    wp-content/plugins/*
#    !wp-content/plugins/nqa-<name>/

# ─── Always ignore these, even inside tracked dirs (last match wins) ───
.DS_Store
Thumbs.db
*.swp
node_modules/
vendor/
*.log
*.sql
*.sql.gz
.env
.env.*
wp-config.php
wp-config-local.php
auth.json
